{
  "name": "@sow/desktop",
  "version": "0.0.0",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "build:sow": "pnpm --filter @sow/contracts --filter @sow/domain --filter @sow/policy --filter @sow/db --filter @sow/workflows --filter @sow/knowledge --filter @sow/providers --filter @sow/integrations --filter @sow/worker run build",
    "build:worker": "node worker-host.build.mjs",
    "dev": "pnpm run build:sow && pnpm run build:worker && electron-vite dev",
    "build": "pnpm run build:sow && electron-vite build && pnpm run build:worker",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "lint": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json"
  },
  "dependencies": {
    "@sow/contracts": "workspace:*",
    "@trpc/client": "^11.18.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@sow/worker": "workspace:*",
    "@trpc/server": "^11.18.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.2",
    "electron": "^32.2.0",
    "electron-vite": "^2.3.0",
    "esbuild": "^0.21.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vitest": "^2.1.3"
  }
}
