{
  "name": "@sow/workflows",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "sow-built": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./*": {
      "sow-built": "./dist/*.js",
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@sow/contracts": "workspace:*",
    "@sow/domain": "workspace:*",
    "@sow/db": "workspace:*",
    "@sow/policy": "workspace:*",
    "@sow/knowledge": "workspace:*",
    "@sow/providers": "workspace:*",
    "@sow/integrations": "workspace:*",
    "@temporalio/common": "^1.19.0",
    "@temporalio/workflow": "^1.19.0"
  },
  "devDependencies": {
    "@temporalio/activity": "^1.19.0",
    "@temporalio/testing": "^1.19.0",
    "@temporalio/worker": "^1.19.0",
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.3"
  }
}
