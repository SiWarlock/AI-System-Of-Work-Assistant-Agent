{
  "type": "object",
  "properties": {
    "mode": {
      "type": "string",
      "enum": [
        "read_only",
        "scoped_write"
      ]
    },
    "allowedTools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "deniedTools": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowsMutating": {
      "type": "boolean"
    }
  },
  "required": [
    "mode",
    "allowedTools",
    "deniedTools",
    "allowsMutating"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sow:tool-policy"
}
