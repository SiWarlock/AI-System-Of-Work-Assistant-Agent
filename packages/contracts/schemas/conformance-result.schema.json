      "enum": [
        "provider",
        "runtime"
      ]
    },
    "subjectId": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
