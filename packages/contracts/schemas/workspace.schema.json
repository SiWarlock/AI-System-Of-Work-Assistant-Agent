{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": [
        "employer_work",
        "personal_business",
        "personal_life"
      ]
    },
    "dataOwner": {
      "type": "string",
      "enum": [
        "employer",
        "user",
        "client"
      ]
    },
    "markdownRepoPath": {
      "type": "string",
      "minLength": 1
    },
    "gbrainBrainId": {
      "type": "string",
      "minLength": 1
    },
    "defaultVisibility": {
      "type": "string",
      "enum": [
        "isolated",
        "coordination",
        "sanitized",
        "full"
      ]
    },
    "egressPolicy": {
      "type": "object",
      "properties": {
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "allowedProcessors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "rawContentAllowedProcessors": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "employerRawEgressAcknowledged": {
          "type": "boolean"
        },
        "acknowledgedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "workspaceId",
        "allowedProcessors",
        "rawContentAllowedProcessors",
        "employerRawEgressAcknowledged"
      ],
      "additionalProperties": false
    },
    "providerMatrix": {
      "type": "object",
      "properties": {
        "workspaceId": {
          "type": "string",
          "minLength": 1
        },
        "allowedProviders": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "claude",
              "openai",
              "openrouter",
              "ollama",
              "lm_studio"
            ]
          }
        },
        "capabilityDefaults": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              {
                "type": "object",
                "properties": {
                  "runtime": {
                    "type": "string",
                    "minLength": 1
                  },
                  "model": {
                    "type": "string",
                    "minLength": 1
                  },
                  "endpoint": {
                    "type": "string",
                    "minLength": 1
                  },
                  "egressClass": {
                    "type": "string",
                    "enum": [
                      "local",
                      "cloud"
                    ]
                  }
                },
                "required": [
                  "runtime",
                  "model",
                  "endpoint",
                  "egressClass"
                ],
                "additionalProperties": false
              },
              {
                "type": "object",
                "properties": {
                  "provider": {
                    "type": "string",
                    "enum": [
                      "claude",
                      "openai",
                      "openrouter",
                      "ollama",
                      "lm_studio"
                    ]
                  },
                  "model": {
                    "type": "string",
                    "minLength": 1
                  },
                  "endpoint": {
                    "type": "string",
                    "minLength": 1
                  },
                  "egressClass": {
                    "type": "string",
                    "enum": [
                      "local",
                      "cloud"
                    ]
                  }
                },
                "required": [
                  "provider",
                  "model",
                  "endpoint",
                  "egressClass"
                ],
                "additionalProperties": false
              }
            ]
          }
        },
        "rawCloudEgressEnabled": {
          "type": "boolean"
        },
        "localProviderPreference": {
          "type": "string",
          "enum": [
            "claude",
            "openai",
            "openrouter",
            "ollama",
            "lm_studio"
          ]
        }
      },
      "required": [
        "workspaceId",
        "allowedProviders",
        "capabilityDefaults",
        "rawCloudEgressEnabled"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "id",
    "name",
    "type",
    "dataOwner",
    "markdownRepoPath",
    "gbrainBrainId",
    "defaultVisibility",
    "egressPolicy",
    "providerMatrix"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sow:workspace"
}
