{
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "actionRef": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "approved",
        "edited",
        "rejected",
        "deferred",
        "expired"
      ]
    },
    "actor": {
      "type": "string",
      "minLength": 1
    },
    "channel": {
      "type": "string",
      "enum": [
        "mac",
        "telegram"
      ]
    },
    "payloadHash": {
      "type": "string",
      "minLength": 1
    },
    "snoozeUntil": {
      "type": "string",
      "format": "date-time"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": [
    "id",
    "actionRef",
    "status",
    "actor",
    "channel",
    "payloadHash"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sow:approval"
}
