{
  "type": "object",
  "properties": {
    "gbrainSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "gbrainTag": {
      "type": "string",
      "minLength": 1
    },
    "gbrainRepo": {
      "type": "string",
      "format": "uri"
    },
    "indexSchemaVersion": {
      "type": "integer",
      "minimum": 0
    },
    "validatedOn": {
      "type": "string",
      "minLength": 1
    },
    "validationRef": {
      "type": "string",
      "minLength": 1
    },
    "writeThroughEnabled": {
      "type": "boolean",
      "default": false
    }
  },
  "required": [
    "gbrainSha",
    "gbrainTag",
    "gbrainRepo",
    "indexSchemaVersion",
    "validatedOn",
    "validationRef"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sow:gbrain-pin"
}
