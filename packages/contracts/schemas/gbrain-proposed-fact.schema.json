{
  "type": "object",
  "properties": {
    "proposalId": {
      "type": "string",
      "minLength": 1
    },
    "workspaceId": {
      "type": "string",
      "minLength": 1
    },
    "factKind": {
      "type": "string",
      "enum": [
        "page",
        "link",
        "timeline",
        "tag",
        "frontmatter_value"
      ]
    },
    "proposedContent": {
      "type": "object",
      "additionalProperties": {}
    },
    "evidenceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "kind": {
            "type": "string",
            "enum": [
              "markdown",
              "source_envelope"
            ]
          },
          "ref": {
            "type": "string",
            "minLength": 1
          },
          "span": {
            "type": "string",
            "minLength": 1
          },
          "block": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "kind",
          "ref"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "generatedBy": {
      "type": "string",
      "enum": [
        "synthesis",
        "dream",
        "patterns",
        "minion"
      ]
    },
    "requiresApproval": {
      "type": "boolean",
      "default": true
    }
  },
  "required": [
    "proposalId",
    "workspaceId",
    "factKind",
    "proposedContent",
    "evidenceRefs",
    "confidence",
    "generatedBy"
  ],
  "additionalProperties": false,
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "sow:gbrain-proposed-fact"
}
